# Copie este arquivo para .env e preencha com valores reais.
# Nunca commitar o .env real.

DATABASE_URL=sqlite:///local.db

META_APP_ID=
META_APP_SECRET=
WEBHOOK_VERIFY_TOKEN=

WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

GOOGLE_SHEETS_CREDENTIALS_PATH=

# Chave Fernet para criptografar tokens de System User em repouso.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Token para proteger as rotas /admin/* — qualquer string longa e aleatória.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=

# Senha do dashboard web (pode ser igual ao ADMIN_TOKEN ou diferente)
WEB_PASSWORD=

# Chave de sessão Flask — gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Minutos de tolerância antes de marcar um lead como divergente (padrão: 30)
DIVERGENCE_WINDOW_MINUTES=30
